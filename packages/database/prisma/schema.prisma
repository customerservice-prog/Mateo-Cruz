// Mateo Cruz - Prisma Database Schema
// Autonomous Cinematic YouTube Video Studio

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  avatars  Avatar[]
  projects Project[]
}

model Avatar {
  id               String   @id @default(uuid())
  userId           String
  name             String
  description      String   @default("")
  promptBase       String   @db.Text
  negativePrompt   String   @db.Text @default("")
  referenceImageUrl String   @default("")
  voiceId          String   @default("")
  createdAt        DateTime @default(now())

  user     User              @relation(fields: [userId], references: [id])
  projects Project[]
  memories CharacterMemory[]
}

model Project {
  id                  String        @id @default(uuid())
  userId              String
  avatarId            String
  title               String?
  prompt              String        @db.Text
  status              String        @default("queued")
  targetLengthSeconds Int           @default(1800)
  scriptText          String?       @db.Text
  conceptJson         Json?
  outlineJson         Json?
  voiceUrl            String?
  subtitlesUrl        String?
  musicUrl            String?
  finalVideoUrl       String?
  retryCount          Int           @default(0)

  // Step tracking for resume capability
  stepConcept  Boolean @default(false)
  stepOutline  Boolean @default(false)
  stepScript   Boolean @default(false)
  stepScenes   Boolean @default(false)
  stepImages   Boolean @default(false)
  stepVoice    Boolean @default(false)
  stepRender   Boolean @default(false)
  stepQuality  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id])
  avatar         Avatar          @relation(fields: [avatarId], references: [id])
  scenes         Scene[]
  assets         Asset[]
  qualityReports QualityReport[]
  youtubePackage YoutubePackage?
}

model Scene {
  id              String   @id @default(uuid())
  projectId       String
  index           Int
  durationSeconds Int
  narration       String   @db.Text
  emotion         String?
  environment     String?
  visualPrompt    String   @db.Text
  motionPrompt    String?  @db.Text
  imageUrl        String?
  videoUrl        String?
  sfxJson         Json?
  status          String   @default("pending")
  createdAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId, index])
}

model Asset {
  id        String   @id @default(uuid())
  projectId String
  type      String   // "image" | "video" | "audio" | "subtitle"
  url       String
  metadata  Json?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

model QualityReport {
  id        String   @id @default(uuid())
  projectId String   @unique
  score     Int
  passed    Boolean
  issues    Json     // QualityIssue[]
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

model YoutubePackage {
  id              String   @id @default(uuid())
  projectId       String   @unique
  title           String
  description     String   @db.Text
  tags            String[]
  thumbnailPrompt String   @db.Text @default("")
  chapters        Json     // { timeSeconds: number, title: string }[]
  pinnedComment   String   @default("")
  createdAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

model CharacterMemory {
  id            String   @id @default(uuid())
  avatarId      String
  projectId     String
  summary       String   @db.Text
  emotionalState String
  keyEvents     Json     // string[]
  createdAt     DateTime @default(now())

  avatar Avatar @relation(fields: [avatarId], references: [id])

  @@index([avatarId, createdAt])
}

# Database (Railway Postgres or local Docker)
DATABASE_URL=postgresql://mateocruz:mateocruz_dev@localhost:5432/mateocruz

# Redis (Railway Redis or local Docker)
REDIS_HOST=localhost
REDIS_PORT=6379

# OpenAI — script, concept, YouTube metadata (never commit real keys; set in Railway Variables)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Replicate — Flux scene images
REPLICATE_API_TOKEN=r8_...

# ElevenLabs — Mateo voice (stability 0.72, similarity_boost 0.85, style 0.45 in app code)
ELEVENLABS_API_KEY=
ELEVENLABS_MATEO_VOICE_ID=

# Cloudflare R2
CLOUDFLARE_R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=mateo-cruz
CLOUDFLARE_R2_PUBLIC_URL=https://pub-YOUR_HASH.r2.dev

# Worker temp dir (must be writable; use /tmp/mateo-cruz on Linux/Docker)
TMP_DIR=/tmp/mateo-cruz

# Web
NEXT_PUBLIC_APP_URL=http://localhost:3000

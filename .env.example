# Mateo Cruz - Environment Variables
# Copy this to .env

DATABASE_URL="postgresql://user:password@localhost:5432/mateocruz"
REDIS_HOST="localhost"
REDIS_PORT="6379"
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"
ELEVENLABS_API_KEY="..."
ELEVENLABS_VOICE_ID="..."
RUNWAY_API_KEY="..."
LUMA_API_KEY="..."
REPLICATE_API_TOKEN="r8_..."
R2_ACCOUNT_ID="..."
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_BUCKET_NAME="mateocruz-assets"
R2_PUBLIC_URL="https://assets.yourdomain.com"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_SECRET="..."
NEXTAUTH_URL="http://localhost:3000"
ANTHROPIC_API_KEY="sk-ant-..."
FFMPEG_PATH="/usr/bin/ffmpeg"
FFPROBE_PATH="/usr/bin/ffprobe"
TEMP_DIR="/tmp/mateocruz"
USE_ANIMATED_CLIPS="false"
MAX_VIDEO_LENGTH_SECONDS="3600"
MAX_SCENES_PER_VIDEO="300"
DEFAULT_SCENE_DURATION="8"
